; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Letter-Blast"
run/main_scene="uid://startscreen"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://cqhl72wc38rbj"

[autoload]

GameStateManager="*res://scripts/game_state_manager.gd"
SettingsManager="*res://scripts/settings_manager.gd"
StatsManager="*res://scripts/stats_manager.gd"
LeitnerManager="*res://scripts/leitner_manager.gd"
SceneManager="*uid://2iy8wfgenjka"
Scenes="*uid://larj2tqblw3f"

[editor_plugins]

enabled=PackedStringArray("res://addons/codeandweb.texturepacker/plugin.cfg", "res://addons/scene_manager/plugin.cfg", "res://addons/sprite_frames_exported_textures/plugin.cfg")

[importer]

ignore=PackedStringArray("docs")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
viewport/hdr_2d=true
